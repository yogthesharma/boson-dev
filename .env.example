# Used by docker compose (copy to .env and adjust if needed)
POSTGRES_USER=boson
POSTGRES_PASSWORD=boson
POSTGRES_DB=boson

# Host port for Postgres (default 5433 to avoid conflict with a local install).
# The server inside the compose network always talks to postgres:5432.
POSTGRES_PORT=5433
REDIS_PORT=6379
SERVER_PORT=3001
WEB_PORT=8080

# Used only when running pnpm dev locally (server outside Docker).
DATABASE_URL=postgres://boson:boson@localhost:5433/boson
REDIS_URL=redis://localhost:6379
PORT=3001
